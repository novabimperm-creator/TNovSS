<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ProjectGuid>{236CD423-0F47-4216-89B7-DBE203F36564}</ProjectGuid>
    <RootNamespace>TNovSS</RootNamespace>
    <AssemblyName>TNovSS</AssemblyName>
  </PropertyGroup>

  <!-- Revit-плагин работает только на Windows; убирает CA1416 на .NET 10. -->
  <PropertyGroup Condition="'$(TargetFramework)' != 'net48'">
    <SupportedOSPlatformVersion>7.0</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TNovCommon\TNovCommon.csproj" Private="false" />
  </ItemGroup>

  <!-- ===== Версионирование ===== -->
  <Target Name="PreBuild" BeforeTargets="PreBuildEvent">
    <Exec Command="powershell -ExecutionPolicy Bypass -File &quot;$(ProjectDir)UpdateVersion.ps1&quot;" />
  </Target>

</Project>
