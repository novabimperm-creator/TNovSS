<Window x:Class="TNovSS.SSNumbererWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TNovSS"
        mc:Ignorable="d"
        Width="420"
        SizeToContent="Height"
        d:DataContext="{d:DesignInstance local:SSNumbererViewModel}"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="12"
            Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="1">
        <StackPanel Margin="18">
            <Border MouseDown="TitleBar_MouseDown"
                    Background="Transparent"
                    Cursor="Arrow"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="35"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="АДРЕСАТОР"
                               Grid.Column="0"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="i"
                            Grid.Column="1"
                            Style="{StaticResource CloseButtonStyleMini}"
                            Click="HelpButton_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="✕"
                            Grid.Column="2"
                            Style="{StaticResource CloseButtonStyleMini}"
                            Click="escButton_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Параметр:"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Марка"
                               Foreground="White"
                               FontWeight="SemiBold"/>
                    <TextBlock Text=" (системный)"
                               Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Name="text1"
                           Grid.Row="0"
                           Grid.Column="0"
                           Text="Номер цепи"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           TextAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,6"/>
                <TextBlock Name="text2"
                           Grid.Row="0"
                           Grid.Column="2"
                           Text="Номер выхода*"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           TextAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,6"/>
                <StackPanel Grid.Row="0"
                            Grid.Column="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,6">
                    <TextBlock Name="text3"
                               Text="Стартовый №"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               VerticalAlignment="Bottom"/>
                    <Button Content="v"
                            x:Name="loadButton"
                            Style="{StaticResource CloseButtonStyleMini}"
                            Command="{Binding GetLastNumberCommand}"
                            ToolTip="Подставить последний номер"
                            Margin="4,0,0,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>

                <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Name="textBox1"
                         Text="{Binding circuitvalue}"
                         Style="{StaticResource DarkTextBoxStyle}"
                         Height="36"
                         TextAlignment="Center"/>
                <TextBox Grid.Row="1"
                         Grid.Column="2"
                         Name="textBox2"
                         Text="{Binding circuitsection}"
                         Style="{StaticResource DarkTextBoxStyle}"
                         Height="36"
                         TextAlignment="Center"/>
                <TextBox Grid.Row="1"
                         Grid.Column="4"
                         Name="textBox3"
                         Text="{Binding startvalue, Mode=TwoWay}"
                         Style="{StaticResource DarkTextBoxStyle}"
                         Height="36"
                         TextAlignment="Center"/>

                <TextBlock Name="text2a"
                           Grid.Row="2"
                           Grid.Column="2"
                           Text="*может быть пустым"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Завершить"
                        x:Name="escButton"
                        Style="{StaticResource CloseButtonStyle}"
                        IsCancel="True"
                        Click="escButton_Click"/>
                <Button Grid.Column="2"
                        Content="Старт"
                        x:Name="acceptButton"
                        Style="{StaticResource RunButtonStyle}"
                        Margin="0"
                        IsDefault="True"
                        Command="{Binding NumerateCommand}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
