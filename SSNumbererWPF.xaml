<Window x:Class="TNovSS.SSNumbererWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TNovSS"
             mc:Ignorable="d" Width="400"
        d:DataContext="{d:DesignInstance local:SSNumbererViewModel}"
            WindowStartupLocation="CenterScreen" 
                                       AllowsTransparency="True"
Background="Transparent" 
            ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
              ResizeBorderThickness="5"
              GlassFrameThickness="0"
              CornerRadius="1"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="12"
    Background="White"
    BorderBrush="#FF008E43"
    BorderThickness="1">
        <Grid>
            <!-- Верхняя панель (кастомный заголовок) -->
            <Border Height="30" CornerRadius="12 12 0 0"
    Background="#FF008E43" 
    VerticalAlignment="Top"
    MouseDown="Border_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}" 
Click="escButton_Click" Content="✕"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="5,0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle2}" 
Click="HelpButton_Click" Content="?"
HorizontalAlignment="Center" VerticalAlignment="Center"
Width="20" Height="20" Margin="0"
WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <TextBlock Text="Адресатор" 
Foreground="White"
VerticalAlignment="Center"
Margin="10,0"/>
                </StackPanel>

            </Border>
            <!-- Основное содержимое -->
            <Border Margin="0,30,0,0">

                <Grid ShowGridLines="False">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="5 px"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5 px"/>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="5 px"/>
                    </Grid.ColumnDefinitions>
                    
                    
                    
                    <StackPanel VerticalAlignment="Center" Margin="5" Grid.Column="1" Grid.Row="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Margin="5" Text="Параметр:" TextWrapping="Wrap" />
                            <TextBlock Margin="5" Text="Марка" FontWeight="Bold"  TextWrapping="Wrap" />
                            <TextBlock Text="(системный)" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </StackPanel>

                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" Margin="5" Grid.Column="1" Grid.Row="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Name="text1" Margin="5" Text="Номер цепи" TextWrapping="Wrap" Width="100" TextAlignment="Left" VerticalAlignment="Bottom"/>
                            <TextBlock Name="text2" Margin="5" Text="Номер выхода*" TextWrapping="Wrap" Width="100" TextAlignment="Center" VerticalAlignment="Bottom"/>
                            <TextBlock Name="text3" Margin="5" Text="Стартовый №" TextWrapping="Wrap" Width="100" TextAlignment="Right" VerticalAlignment="Bottom"/>
                            <Button Style="{StaticResource CustomButtonStyle}" Content="v" x:Name="loadButton" Command="{Binding GetLastNumberCommand}" MinWidth="30" MinHeight="25" />
                        </StackPanel>

                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" Grid.Column="1" Grid.Row="2">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="20">
                            <TextBox Name="textBox1" Text="{Binding circuitvalue}" MinWidth="110" Margin="5 0 5 0" TextAlignment="Center" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                            <TextBox Name="textBox2" Text="{Binding circuitsection}" MinWidth="110" Margin="5 0 5 0" TextAlignment="Center" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                            <TextBox Name="textBox3" Text="{Binding startvalue, Mode=TwoWay}" MinWidth="120" Margin="5 0 5 0" TextAlignment="Center" TextWrapping="Wrap" BorderBrush="#CCCCCC"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" Grid.Column="1" Grid.Row="3">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Name="text2a" Text="*может быть пустым" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Bottom"/>
                        </StackPanel>

                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" Margin="5" Grid.Column="1" Grid.Row="4">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource CustomButtonStyle}" Content="Завершить" x:Name="escButton" IsCancel="True" Click="escButton_Click" MinWidth="120" MinHeight="25" Margin="5" />
                            <Button Style="{StaticResource CustomButtonStyle}" Content="Старт" x:Name="acceptButton" IsDefault="True" Command="{Binding NumerateCommand}" MinWidth="120" MinHeight="25" Margin="5" />
                        </StackPanel>
                    </StackPanel>

                </Grid>

            </Border>
        </Grid>
    </Border>
</Window>
